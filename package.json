{
  "name": "mist",
  "version": "1.0.0",
  "description": "股票市场分析和预警系统 - A-share market analysis and alert system with AI-powered intelligent agents",
  "author": "moyui",
  "private": true,
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "mist": "dist/apps/mist/main.js",
    "mist-mcp": "dist/apps/mcp-server/main.js"
  },
  "scripts": {
    "build": "nest build",
    "build:docker": "nest build mist && nest build chan && nest build mcp-server",
    "db:migrate": "node tools/run-migrations.mjs",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:mist": "nest start mist",
    "start:dev:chan": "nest start chan",
    "start:dev:mcp-server": "nest start mcp-server",
    "start:debug": "nest start --debug --watch",
    "start:debug:chan": "nest start chan --debug --watch",
    "start:debug:mcp-server": "nest start mcp-server --debug --watch",
    "start:prod": "node dist/apps/mist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --runInBand --watchman=false",
    "ci:contracts": "node tools/test-ci-contracts.mjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:chan:shanghai-2024-2025": "jest shanghai-index-2024-2025",
    "test:sync": "node tools/sync-test-data.mjs",
    "test:gen-types": "node tools/generate-type-definitions.mjs",
    "test:full": "pnpm run test && pnpm run test:sync",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@rekog/mcp-nest": "^1.9.7",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.9",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron": "^3.5.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "joi": "^18.0.2",
    "mysql2": "^3.12.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "technicalindicators": "3.1.0",
    "typeorm": "^0.3.20",
    "ws": "^8.20.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^16.2.7",
    "pkg": "^5.8.1",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/config(|/.*)$": "<rootDir>/libs/config/src/$1",
      "^@app/utils(|/.*)$": "<rootDir>/libs/utils/src/$1",
      "^@app/timezone(|/.*)$": "<rootDir>/libs/timezone/src/$1",
      "^@app/shared-data(|/.*)$": "<rootDir>/libs/shared-data/src/$1",
      "^@app/constants(|/.*)$": "<rootDir>/libs/constants/src/$1",
      "^@app/data-collector(|/.*)$": "<rootDir>/apps/mist/src/data-collector/$1",
      "^@test-data(|/.*)$": "<rootDir>/test-data/$1"
    }
  },
  "pkg": {
    "scripts": [
      "dist/apps/mist/main.js",
      "dist/apps/mcp-server/main.js"
    ],
    "assets": [
      "node_modules/**/*"
    ]
  }
}
