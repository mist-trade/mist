# Windows API appliance backend configuration
#
# Copy this file to backend/.env inside the extracted appliance package.
# MySQL runs on the same Windows API machine. Redis is intentionally optional
# for the first appliance release.

NODE_ENV=production
PORT=8001

# MySQL
mysql_server_host=127.0.0.1
mysql_server_port=3306
mysql_server_username=root
mysql_server_password=change_me
mysql_server_database=mist

# Redis is not required by the first Windows appliance path.
redis_server_host=127.0.0.1
redis_server_port=6379
redis_server_db=0

# Data source
DEFAULT_DATA_SOURCE=tdx
TDX_BASE_URL=http://127.0.0.1:9001
TDX_WS_CLIENT_ID=mist-backend-tdx
QMT_WS_CLIENT_ID=mist-backend-qmt

# Optional
AKTOOLS_BASE_URL=http://127.0.0.1:8080
